#!/usr/bin/env bash
# argus-pager 2.0 — OPSEC pre-commit hook
# Activate with: git config core.hooksPath hooks
# Blocks: real GPS coords, real MAC addrs, API keys, forbidden files.

set -e

RED=$'\033[0;31m'; GRN=$'\033[0;32m'; YLW=$'\033[1;33m'; NC=$'\033[0m'

fail=0
say_block() { echo "${RED}[OPSEC BLOCK]${NC} $*" >&2; fail=1; }
say_warn()  { echo "${YLW}[OPSEC WARN]${NC} $*" >&2; }

# Files that must never be staged
FORBIDDEN=(
  "config.json"
  "ignore_lists/mac_list.json"
  "ignore_lists/ssid_list.json"
  "watch_list.json"
  "suspects_db.json"
  "gps_track.csv"
  "gps_log.csv"
  "imsi_alerts.jsonl"
  "silent_sms.jsonl"
  "rat_history.json"
  "pairings.json"
  "external_intel_cache.json"
)

staged=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$staged" ] && exit 0

for f in $staged; do
  for bad in "${FORBIDDEN[@]}"; do
    [ "$f" = "$bad" ] && say_block "Forbidden file staged: $f"
  done
  case "$f" in
    *.pcap|*.pcapng|*.kismet|*.kismet-journal) say_block "Capture file staged: $f" ;;
    loot/*|reports/*|logs/*|upload_queue/*|cell_cache/*) say_block "Data dir staged: $f" ;;
    incidents/*|deauth_*) say_block "Forensic incident staged: $f" ;;
    walk_*|gps_track_*) say_block "GPS export staged: $f" ;;
    *.log) say_block "Log file staged: $f" ;;
  esac
done

# Scan diff for sensitive content
diff_content=$(git diff --cached --no-color)
[ -z "$diff_content" ] && [ "$fail" -eq 0 ] && exit 0

# 1) Real GPS coordinates (anything not 0.0 / 0.000000 / placeholder)
#    Match patterns "lat": 12.345678 with non-zero non-trivial value
gps_hits=$(echo "$diff_content" | grep -E '^\+' \
  | grep -E '"(lat|lon|latitude|longitude)"\s*:\s*-?(([1-9][0-9]*\.[0-9]+)|(0\.0*[1-9][0-9]*))' \
  | grep -vE '0\.000000|"\s*(lat|lon|latitude|longitude)"\s*:\s*0\b' || true)
if [ -n "$gps_hits" ]; then
  say_block "Possible real GPS coordinate in diff (use 0.000000 placeholders):"
  echo "$gps_hits" | head -3 | sed 's/^/    /' >&2
fi

# 2) Real-looking MAC addresses (XX:XX:XX:XX:XX:XX). Allow common
#    placeholder / test patterns; flag everything else.
#
# Whitelist patterns:
#   aa:bb:cc:dd:ee:??     — generic placeholder used in docs + CYT-purge
#   aa:00:00:00:00:??     — synthetic deauth_test source
#   00:00:00:00:00:00     — null
#   ff:ff:ff:ff:ff:ff     — broadcast
#   11:22:33:44:55:66     — old anonymisation marker
#   ca:fe:ca:fe:??:??     — CAFE-test markers
#   bc:bc:bc:bc:bc:bc     — repeating test value
#   01:02:03:04:05:06     — counter-test
#   de:ad:be:ef:??:??     — DEAD-BEEF marker
if echo "$diff_content" | grep -E '^\+' \
   | grep -qiE '\b([0-9a-f]{2}:){5}[0-9a-f]{2}\b'; then
  bad_macs=$(echo "$diff_content" | grep -E '^\+' \
    | grep -ioE '\b([0-9a-f]{2}:){5}[0-9a-f]{2}\b' \
    | grep -ivE '^(aa:bb:cc:dd:ee:[0-9a-f]{2}|aa:00:00:00:00:[0-9a-f]{2}|00:00:00:00:00:00|ff:ff:ff:ff:ff:ff|11:22:33:44:55:66|ca:fe:ca:fe:[0-9a-f]{2}:[0-9a-f]{2}|bc:bc:bc:bc:bc:bc|01:02:03:04:05:06|de:ad:be:ef:[0-9a-f]{2}:[0-9a-f]{2})$' || true)
  if [ -n "$bad_macs" ]; then
    say_block "Real-looking MAC address(es) in diff: $bad_macs"
  fi
fi

# 2a) Wildcard MAC patterns (e.g. "aa:bb:cc:dd:ee:??"). The non-wildcard
#     bytes can still leak a real OUI / device sector. Allowed wildcard
#     patterns must use a placeholder OUI from the whitelist below.
#
# Whitelist (every byte is hex OR exactly two '?'):
#   aa:bb:cc:dd:ee:??   aa:bb:cc:dd:??:??   aa:bb:cc:??:??:??
#   aa:00:00:00:00:??
#   ca:fe:ca:fe:??:??   ca:fe:ca:??:??:??
#   de:ad:be:ef:??:??   de:ad:be:??:??:??
if echo "$diff_content" | grep -E '^\+' \
   | grep -qiE '\b([0-9a-f?]{2}:){5}[0-9a-f?]{2}\b'; then
  pat_hits=$(echo "$diff_content" | grep -E '^\+' \
    | grep -ioE '\b([0-9a-f?]{2}:){5}[0-9a-f?]{2}\b' \
    | grep -E '\?' \
    | grep -ivE '^(aa:bb:cc:dd:ee:\?\?|aa:bb:cc:dd:\?\?:\?\?|aa:bb:cc:\?\?:\?\?:\?\?|aa:00:00:00:00:\?\?|ca:fe:ca:fe:\?\?:\?\?|ca:fe:ca:\?\?:\?\?:\?\?|de:ad:be:ef:\?\?:\?\?|de:ad:be:\?\?:\?\?:\?\?)$' || true)
  if [ -n "$pat_hits" ]; then
    say_block "Wildcard MAC pattern with real OUI in diff: $pat_hits"
    echo "    Use de:ad:be:ef:??:?? or ca:fe:ca:fe:??:?? as placeholder." >&2
  fi
fi

# 3) API keys (WiGLE token, OpenCelliD pf-token, Shodan, Fingerbank)
key_re='(api[_-]?(key|token)|wigle[_-]?api|opencellid[_-]?key|shodan[_-]?api|fingerbank[_-]?api)'
if echo "$diff_content" | grep -E '^\+' | grep -iE "$key_re" \
   | grep -qE '[:=]\s*"[A-Za-z0-9_\-]{12,}"'; then
  say_block "Possible API key/token in diff"
fi

# 4) Bearer-token / hex blobs > 32 chars
if echo "$diff_content" | grep -E '^\+' | grep -qE '\b[A-Fa-f0-9]{40,}\b'; then
  say_warn "Long hex string detected — verify it isn't a credential"
fi

# 4b) IMEI / IMSI — 14-15 digit numbers, esp. in known fields
#   IMEI: 15 digits, IMSI: 14-15 digits. Block any explicit IMEI/IMSI:VALUE.
if echo "$diff_content" | grep -E '^\+' \
   | grep -qiE '"?(imei|imsi)"?\s*[:=]\s*"?[0-9]{14,16}"?'; then
  bad_id=$(echo "$diff_content" | grep -E '^\+' \
    | grep -ioE '"?(imei|imsi)"?\s*[:=]\s*"?[0-9]{14,16}"?' \
    | grep -vE '"?(imei|imsi)"?\s*[:=]\s*"?(0{14,16}|1{14,16})"?' || true)
  if [ -n "$bad_id" ]; then
    say_block "IMEI/IMSI in diff: $bad_id"
  fi
fi
# Also block bare 15-digit numbers next to "imei"/"imsi" tokens
if echo "$diff_content" | grep -E '^\+' \
   | grep -qiE '\b(imei|imsi)\b.*\b[0-9]{14,16}\b'; then
  say_warn "IMEI/IMSI-shaped number near imei/imsi keyword — verify"
fi

# 5) SSH private keys
# Use -e so leading dashes aren't parsed as options.
if echo "$diff_content" | grep -qE -e '-----BEGIN (RSA|OPENSSH|EC|DSA) PRIVATE KEY-----'; then
  say_block "SSH private key in diff"
fi

if [ "$fail" -ne 0 ]; then
  echo "" >&2
  echo "${RED}═══════════════════════════════════════════════════════${NC}" >&2
  echo "${RED} Commit blocked by OPSEC pre-commit hook.${NC}" >&2
  echo "${RED} Fix the issues above or use placeholder values.${NC}" >&2
  echo "${RED}═══════════════════════════════════════════════════════${NC}" >&2
  exit 1
fi

echo "${GRN}[OPSEC OK]${NC} pre-commit checks passed."
exit 0
